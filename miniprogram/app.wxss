/**app.wxss - 莫兰迪色系全局样式**/

/* ===== 全局基础样式 ===== */
page {
  background: #F5F5F3;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #2C3E3E;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ===== 色彩系统（莫兰迪色系）===== */
:root {
  --color-primary: #7C9A92;
  --color-secondary: #B8C4BB;
  --color-background: #F5F5F3;
  --color-text: #2C3E3E;
  --color-text-secondary: #5A6C6C;
  --color-accent: #E8B4B8;
  --color-warning: #D4A574;
  --color-danger: #C4786A;
  --color-success: #8BA888;
}

/* ===== 字体系统 ===== */
.font-title {
  font-size: 44rpx;
  font-weight: 300;
  letter-spacing: 0.02em;
}

.font-subtitle {
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: 0.01em;
}

.font-body {
  font-size: 28rpx;
  font-weight: 400;
}

.font-caption {
  font-size: 24rpx;
  font-weight: 300;
  color: #5A6C6C;
}

/* ===== 间距系统 ===== */
.spacing-xs { margin: 8rpx; }
.spacing-sm { margin: 16rpx; }
.spacing-md { margin: 24rpx; }
.spacing-lg { margin: 32rpx; }
.spacing-xl { margin: 48rpx; }

/* ===== 圆角系统 ===== */
.radius-sm { border-radius: 12rpx; }
.radius-md { border-radius: 16rpx; }
.radius-lg { border-radius: 24rpx; }
.radius-xl { border-radius: 32rpx; }

/* ===== 阴影系统（轻微阴影）===== */
.shadow-sm { box-shadow: 0 2rpx 8rpx rgba(44, 62, 62, 0.04); }
.shadow-md { box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06); }
.shadow-lg { box-shadow: 0 8rpx 20rpx rgba(44, 62, 62, 0.08); }

/* ===== 卡片基础样式 ===== */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
}

/* ===== 按钮基础样式 ===== */
button {
  background: initial;
  border-radius: 48rpx;
  font-weight: 400;
  letter-spacing: 0.01em;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

.btn-primary {
  background: #7C9A92;
  color: #FFFFFF;
  height: 96rpx;
  font-size: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
}

.btn-secondary {
  background: #FFFFFF;
  color: #2C3E3E;
  height: 96rpx;
  font-size: 30rpx;
  border: 2rpx solid #B8C4BB;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.04);
}

/* ===== 输入框基础样式 ===== */
.input {
  height: 96rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  border: 2rpx solid #B8C4BB;
  box-sizing: border-box;
}

.input:focus {
  border-color: #7C9A92;
  box-shadow: 0 0 0 4rpx rgba(124, 154, 146, 0.1);
}

.input::placeholder {
  color: #B8C4BB;
  font-weight: 300;
}

/* ===== 容器基础样式 ===== */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

/* ===== 页面头部基础样式 ===== */
.page-header {
  padding: 48rpx 32rpx 32rpx;
  background: #FFFFFF;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.04);
}

.page-title {
  font-size: 44rpx;
  font-weight: 300;
  color: #2C3E3E;
  letter-spacing: 0.02em;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  font-weight: 300;
  color: #5A6C6C;
  letter-spacing: 0.01em;
}

/* ===== 状态颜色 ===== */
.status-normal { color: #8BA888; }
.status-warning { color: #D4A574; }
.status-danger { color: #C4786A; }
.status-success { color: #7C9A92; }

/* ===== 标签样式 ===== */
.tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 300;
  display: inline-block;
}

.tag-primary {
  background: rgba(124, 154, 146, 0.1);
  color: #7C9A92;
}

.tag-warning {
  background: rgba(212, 165, 116, 0.1);
  color: #D4A574;
}

.tag-danger {
  background: rgba(196, 120, 106, 0.1);
  color: #C4786A;
}

/* ===== 列表项基础样式 ===== */
.list-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 62, 0.04);
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}

.list-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(44, 62, 62, 0.02);
}

/* ===== 图标容器样式 ===== */
.icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(124, 154, 146, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

/* ===== 加载状态 ===== */
.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #B8C4BB;
  border-top-color: #7C9A92;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #5A6C6C;
  font-weight: 300;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(124, 154, 146, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 300;
  color: #2C3E3E;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  font-weight: 300;
  color: #5A6C6C;
}

/* ===== 模态框基础样式 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 62, 0.4);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  backdrop-filter: blur(8rpx);
}

.modal-card {
  width: 85%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 20rpx 40rpx rgba(44, 62, 62, 0.12);
  animation: modalFadeIn 0.3s ease-out;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #2C3E3E;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-body {
  font-size: 28rpx;
  font-weight: 300;
  color: #5A6C6C;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.modal-buttons {
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn-cancel {
  background: #F5F5F3;
  color: #5A6C6C;
}

.modal-btn-confirm {
  background: #7C9A92;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
}