<!-- pages/create_item/create_item.wxml -->
<view class="page">
  <view class="header">
    <text class="title">{{mode === 'edit' ? '编辑物品' : '添加物品'}}</text>
    <text class="subtitle">{{mode === 'edit' ? '修改物品信息' : '记录新物品到库存'}}</text>
  </view>

  <view class="card">
    <view wx:if="{{isLoading}}" class="loading">
      <view class="spinner"></view>
      <text>正在加载...</text>
    </view>

    <block wx:else>
      <!-- 快捷物品选择区 -->
      <view class="quick-section" wx:if="{{mode === 'add'}}">
        <view class="quick-header">
          <text class="quick-title">快捷选择</text>
          <view class="quick-search-box">
            <input 
              class="quick-search-input"
              type="text"
              placeholder="搜索物品..."
              placeholder-class="placeholder"
              value="{{quickSearchText}}"
              bindinput="onQuickSearch"
            />
          </view>
        </view>
        <scroll-view class="quick-scroll" scroll-x>
          <view class="quick-list">
            <view 
              class="quick-item {{item.name === name ? 'active' : ''}} {{item.isHistory ? 'history' : ''}}"
              wx:for="{{filteredQuickItems}}"
              wx:key="name"
              bindtap="selectQuickItem"
              data-item="{{item}}"
            >
              {{item.name}}
            </view>
            <view class="quick-empty" wx:if="{{filteredQuickItems.length === 0}}">
              未找到匹配的物品
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- 物品名称 -->
      <view class="field">
        <text class="field-label required">物品名称</text>
        <input 
          class="field-input"
          type="text"
          placeholder="例如：牛奶、鸡蛋、纸巾"
          placeholder-class="placeholder"
          bindinput="onNameInput"
          value="{{name}}"
        />
        
      </view>

      <!-- 数量 -->
      <view class="field">
        <text class="field-label">数量</text>
        <view class="quantity-row">
          <input 
            class="qty-input"
            type="number"
            placeholder="请输入数量"
            placeholder-class="placeholder"
            value="{{quantity}}"
            bindinput="onQuantityInput"
          />
          <view class="unit-picker" bindtap="showUnitPicker">
            <text class="unit-text">{{unit}}</text>
            <text class="arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 保质期 -->
      <view class="field">
        <text class="field-label">保质期</text>
        <picker 
          mode="date"
          value="{{expiryDate}}"
          start="{{startDate}}"
          bindchange="onExpiryDateChange"
        >
          <view class="field-picker {{expiryDate ? 'active' : ''}}">
            {{expiryDate ? expiryDate : '请选择过期日期'}}
          </view>
        </picker>
        <text class="field-hint">设置保质期后，我们会自动提醒您</text>
      </view>

      <!-- 备注 -->
      <view class="field">
        <text class="field-label">备注</text>
        <textarea 
          class="field-textarea"
          placeholder="添加备注信息（可选）"
          placeholder-class="placeholder"
          bindinput="onRemarkInput"
          value="{{remark}}"
          maxlength="200"
        />
      </view>

      <!-- 保存按钮 -->
      <view class="submit-area">
        <button 
          class="submit-btn"
          type="primary"
          bindtap="onSubmit"
          loading="{{isSaving}}"
          disabled="{{isSaving || !name}}"
        >
          {{mode === 'edit' ? (isSaving ? '保存中...' : '保存修改') : (isSaving ? '保存中...' : '保存物品')}}
        </button>
      </view>
    </block>
  </view>

  <!-- 单位选择弹窗 -->
  <view class="unit-modal" wx:if="{{showUnitModal}}" bindtap="hideUnitPicker">
    <view class="unit-modal-content" catchtap="preventHide">
      <view class="unit-modal-header">
        <text class="unit-modal-title">选择单位</text>
        <text class="unit-modal-close" bindtap="hideUnitPicker">×</text>
      </view>
      <view class="unit-search-box">
        <input 
          class="unit-search-input"
          type="text"
          placeholder="搜索单位..."
          placeholder-class="placeholder"
          value="{{unitSearchText}}"
          bindinput="onUnitSearch"
          focus
        />
      </view>
      <scroll-view class="unit-list" scroll-y>
        <view 
          class="unit-item {{item === unit ? 'active' : ''}}"
          wx:for="{{filteredUnits}}"
          wx:key="*this"
          bindtap="selectUnit"
          data-unit="{{item}}"
        >
          {{item}}
          <text class="check" wx:if="{{item === unit}}">✓</text>
        </view>
        <view class="unit-empty" wx:if="{{filteredUnits.length === 0}}">
          未找到匹配的单位
        </view>
      </scroll-view>
    </view>
  </view>
</view>
