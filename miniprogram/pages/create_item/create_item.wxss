/* pages/create_item/create_item.wxss - 莫兰迪色系清新风格 */

.page {
  min-height: 100vh;
  background: #F5F5F3;
  padding: 32rpx;
}

/* ===== 快捷物品选择区 ===== */
.quick-section {
  margin-bottom: 24rpx;
}

.quick-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.quick-title {
  font-size: 26rpx;
  font-weight: 400;
  color: #2C3E3E;
}

.quick-search-box {
  flex: 1;
  margin-left: 16rpx;
}

.quick-search-input {
  width: 100%;
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #2C3E3E;
  box-sizing: border-box;
  border: 1rpx solid #B8C4BB;
}

.quick-scroll {
  white-space: nowrap;
}

.quick-list {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 12rpx;
  padding: 4rpx 0;
}

.quick-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #5A6C6C;
  border: 1rpx solid #B8C4BB;
  flex-shrink: 0;
  font-weight: 300;
}

.quick-item.active {
  background: rgba(124, 154, 146, 0.1);
  color: #7C9A92;
  border-color: #7C9A92;
}

.quick-item.history {
  background: rgba(139, 168, 136, 0.1);
  border-color: rgba(139, 168, 136, 0.3);
  color: #8BA888;
}

.quick-empty {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  color: #5A6C6C;
  font-weight: 300;
}

/* ===== 头部 ===== */
.header {
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 300;
  color: #2C3E3E;
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 0.02em;
}

.subtitle {
  font-size: 24rpx;
  color: #5A6C6C;
  display: block;
  font-weight: 300;
}

/* ===== 卡片 ===== */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
}

/* ===== 表单字段 ===== */
.field {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 26rpx;
  color: #2C3E3E;
  font-weight: 400;
  display: block;
  margin-bottom: 12rpx;
  margin-left: 4rpx;
}

.field-label.required::after {
  content: '*';
  color: #C4786A;
  margin-left: 6rpx;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  border: 2rpx solid #B8C4BB;
  box-sizing: border-box;
  font-weight: 300;
}

.field-picker {
  width: 100%;
  height: 88rpx;
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #B8C4BB;
  border: 2rpx solid #B8C4BB;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-weight: 300;
}

.field-picker.active {
  color: #2C3E3E;
}

.field-picker::after {
  content: '›';
  color: #B8C4BB;
  font-size: 32rpx;
}

.field-hint {
  font-size: 22rpx;
  color: #5A6C6C;
  margin-top: 8rpx;
  display: block;
  margin-left: 4rpx;
  font-weight: 300;
}

.field-textarea {
  width: 100%;
  height: 140rpx;
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  border: 2rpx solid #B8C4BB;
  font-weight: 300;
  box-sizing: border-box;
}

.placeholder {
  color: #B8C4BB;
}

/* ===== 数量选择 ===== */
.quantity-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-input {
  flex: 1;
  height: 88rpx;
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  border: 2rpx solid #B8C4BB;
  font-weight: 300;
  box-sizing: border-box;
}

.unit-picker {
  width: 120rpx;
  height: 88rpx;
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  border: 2rpx solid #B8C4BB;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-weight: 300;
  box-sizing: border-box;
}

.unit-picker .arrow {
  color: #B8C4BB;
  font-size: 32rpx;
}

/* ===== 单位选择弹窗 ===== */
.unit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 62, 0.4);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(8rpx);
}

.unit-modal-content {
  width: 100%;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  box-shadow: 0 20rpx 40rpx rgba(44, 62, 62, 0.12);
}

.unit-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F3;
}

.unit-modal-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #2C3E3E;
}

.unit-modal-close {
  font-size: 44rpx;
  color: #5A6C6C;
  padding: 0 8rpx;
  line-height: 1;
  font-weight: 300;
}

.unit-search-box {
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F3;
}

.unit-search-input {
  width: 100%;
  height: 72rpx;
  background: #F5F5F3;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  box-sizing: border-box;
  font-weight: 300;
  border: 1rpx solid #B8C4BB;
}

.unit-list {
  max-height: 60vh;
  padding: 8rpx 0;
}

.unit-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  border-bottom: 1rpx solid #F5F5F3;
  font-weight: 300;
}

.unit-item.active {
  color: #7C9A92;
  background: rgba(124, 154, 146, 0.05);
}

.unit-item .check {
  font-size: 28rpx;
  color: #7C9A92;
  font-weight: 400;
}

.unit-empty {
  padding: 48rpx;
  text-align: center;
  font-size: 26rpx;
  color: #5A6C6C;
  font-weight: 300;
}

/* ===== 提交按钮 ===== */
.submit-area {
  margin-top: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #7C9A92;
  color: #FFFFFF;
  font-size: 30rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: 96rpx;
  font-weight: 400;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: #B8C4BB;
  color: #FFFFFF;
  box-shadow: none;
}

/* ===== 加载状态 ===== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #B8C4BB;
  border-top-color: #7C9A92;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading text {
  font-size: 24rpx;
  color: #5A6C6C;
  font-weight: 300;
}