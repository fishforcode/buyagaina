/* pages/create_location/create_location.wxss - 莫兰迪色系清新风格 */

.container {
  min-height: 100vh;
  background: #F5F5F3;
  padding: 32rpx;
}

/* ===== 页面头部 ===== */
.page-header {
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 300;
  color: #2C3E3E;
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 0.02em;
}

.page-subtitle {
  font-size: 24rpx;
  color: #5A6C6C;
  display: block;
  font-weight: 300;
}

/* ===== 表单卡片 ===== */
.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
}

/* ===== 表单项 ===== */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 26rpx;
  font-weight: 400;
  color: #2C3E3E;
  margin-bottom: 12rpx;
}

.label-required::after {
  content: '*';
  color: #C4786A;
  margin-left: 6rpx;
}

.hint {
  font-size: 22rpx;
  color: #5A6C6C;
  margin-top: 8rpx;
  display: block;
  font-weight: 300;
}

/* ===== 输入框 ===== */
.input {
  height: 88rpx;
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  border: 2rpx solid #B8C4BB;
  box-sizing: border-box;
  font-weight: 300;
}

.input:focus {
  border-color: #7C9A92;
  background: #FFFFFF;
}

.placeholder {
  color: #B8C4BB;
  font-weight: 300;
}

/* ===== 图标选择器 ===== */
.icon-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.icon-option {
  width: 88rpx;
  height: 88rpx;
  background: #F5F5F3;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.icon-option.selected {
  background: rgba(124, 154, 146, 0.1);
  border-color: #7C9A92;
  transform: scale(1.05);
}

/* ===== 按钮区域 ===== */
.button-area {
  margin-top: 48rpx;
}

.button-area button {
  width: 100%;
  height: 96rpx;
  background: #7C9A92;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 400;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
}

.button-area button::after {
  border: none;
}

.button-area button[disabled] {
  background: #B8C4BB;
  color: #FFFFFF;
  box-shadow: none;
}

/* ===== 备注输入框 ===== */
.textarea {
  width: 100%;
  min-height: 180rpx;
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  border: 2rpx solid #B8C4BB;
  box-sizing: border-box;
  font-weight: 300;
}