<!-- pages/item_detail/item_detail.wxml - 现代简约风 -->
<view class="page">
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-icon">‹</text>
    </view>
    <text class="nav-title">物品详情</text>
    <view class="nav-placeholder"></view>
  </view>

  <view class="scroll-area">
    <view class="hero-section">
      <view class="hero-icon-wrap">
        <text class="hero-icon">📦</text>
      </view>
      <text class="hero-name">{{item.name}}</text>
      <view class="hero-meta">
        <text class="hero-qty">× {{item.quantity}}</text>
        <view class="hero-status {{item.daysLeft <= 0 ? 'status-expired' : item.daysLeft <= 3 ? 'status-warning' : item.daysLeft <= 7 ? 'status-attention' : 'status-normal'}}">
          {{item.daysLeft <= 0 ? '已过期' : item.daysLeft <= 3 ? '即将过期' : item.daysLeft <= 7 ? '临近过期' : '状态良好'}}
        </view>
      </view>
    </view>

    <view class="card-list">
      <view class="card">
        <view class="card-header">
          <text class="card-title">基本信息</text>
        </view>
        <view class="card-body">
          <view class="info-row">
            <view class="info-label-wrap">
              <text class="info-label">物品名称</text>
            </view>
            <text class="info-value">{{item.name}}</text>
          </view>
          <view class="info-row">
            <view class="info-label-wrap">
              <text class="info-label">当前数量</text>
            </view>
            <text class="info-value">{{item.quantity}}</text>
          </view>
          <view class="info-row">
            <view class="info-label-wrap">
              <text class="info-label">保质期</text>
            </view>
            <view class="info-value-wrap">
              <text class="info-value expiry {{item.daysLeft <= 0 ? 'text-red' : item.daysLeft <= 3 ? 'text-orange' : ''}}">{{item.expiryDate || '未设置'}}</text>
              <text wx:if="{{item.daysLeft !== undefined && item.daysLeft > 0}}" class="info-sub">剩余 {{item.daysLeft}} 天</text>
              <text wx:if="{{item.daysLeft !== undefined && item.daysLeft <= 0}}" class="info-sub">已过期 {{Math.abs(item.daysLeft)}} 天</text>
            </view>
          </view>
          <view wx:if="{{item.remark}}" class="info-row">
            <view class="info-label-wrap">
              <text class="info-label">备注</text>
            </view>
            <text class="info-value">{{item.remark}}</text>
          </view>
        </view>
      </view>

      <view class="card">
        <view class="card-header">
          <text class="card-title">位置信息</text>
        </view>
        <view class="card-body">
          <view class="info-row">
            <view class="info-label-wrap">
              <text class="info-label">所属空间</text>
            </view>
            <view class="info-value-wrap">
              <text class="info-value">{{locationName || '未设置'}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="card">
        <view class="card-header">
          <text class="card-title">操作记录</text>
        </view>
        <view class="card-body">
          <view class="timeline">
            <view class="timeline-item">
              <view class="timeline-line"></view>
              <view class="timeline-dot"></view>
              <view class="timeline-content">
                <text class="timeline-title">物品创建</text>
                <text class="timeline-time">{{item.createTimeDisplay}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </view>

  <view class="action-bar">
    <button class="action-btn action-secondary" bindtap="onEdit">
      <text class="action-btn-text">编辑</text>
    </button>
    <button class="action-btn action-primary" bindtap="onConsume">
      <text class="action-btn-text">消耗</text>
    </button>
  </view>
</view>