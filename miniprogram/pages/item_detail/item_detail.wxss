/* pages/item_detail/item_detail.wxss - 莫兰迪色系清新风格 */

.page {
  min-height: 100vh;
  background: #F5F5F3;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 62, 0.04);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F5F3;
}

.nav-icon {
  font-size: 36rpx;
  color: #2C3E3E;
  font-weight: 300;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #2C3E3E;
}

.nav-placeholder {
  width: 64rpx;
}

.scroll-area {
  flex: 1;
  overflow-y: auto;
}

.hero-section {
  background: #FFFFFF;
  padding: 60rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
  margin-bottom: 24rpx;
}

.hero-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: rgba(124, 154, 146, 0.1);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.hero-icon {
  font-size: 60rpx;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 300;
  color: #2C3E3E;
  margin-bottom: 12rpx;
  letter-spacing: 0.02em;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hero-qty {
  font-size: 26rpx;
  color: #5A6C6C;
  font-weight: 300;
}

.hero-status {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 300;
}

.status-normal {
  background: rgba(139, 168, 136, 0.1);
  color: #8BA888;
}

.status-attention {
  background: rgba(212, 165, 116, 0.1);
  color: #D4A574;
}

.status-warning {
  background: rgba(196, 120, 106, 0.15);
  color: #C4786A;
}

.status-expired {
  background: rgba(196, 120, 106, 0.2);
  color: #C4786A;
}

.card-list {
  padding: 0 24rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
}

.card-header {
  padding: 24rpx 24rpx 16rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 400;
  color: #5A6C6C;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.card-body {
  padding: 0 24rpx 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F3;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label-wrap {
  flex-shrink: 0;
}

.info-label {
  font-size: 26rpx;
  color: #5A6C6C;
  font-weight: 300;
}

.info-value {
  font-size: 26rpx;
  color: #2C3E3E;
  font-weight: 400;
}

.info-value-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.info-sub {
  font-size: 22rpx;
  color: #B8C4BB;
  margin-top: 4rpx;
  font-weight: 300;
}

.text-red {
  color: #C4786A;
}

.text-orange {
  color: #D4A574;
}

.timeline {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  padding-bottom: 20rpx;
}

.timeline-line {
  width: 2rpx;
  background: #E8E8E8;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.timeline-dot {
  width: 12rpx;
  height: 12rpx;
  background: #7C9A92;
  border-radius: 50%;
  margin-right: 16rpx;
  margin-top: 6rpx;
  flex-shrink: 0;
}

.timeline-content {
  flex: 1;
}

.timeline-title {
  font-size: 26rpx;
  color: #2C3E3E;
  font-weight: 400;
  display: block;
  margin-bottom: 4rpx;
}

.timeline-time {
  font-size: 22rpx;
  color: #5A6C6C;
  font-weight: 300;
}

.bottom-space {
  height: 160rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx 40rpx;
  background: #FFFFFF;
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -4rpx 12rpx rgba(44, 62, 62, 0.06);
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.action-secondary {
  background: #F5F5F3;
  color: #5A6C6C;
}

.action-primary {
  background: #7C9A92;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
}