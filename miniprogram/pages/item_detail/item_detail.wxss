/* pages/item_detail/item_detail.wxss - 清新简约风 */

.container {
  min-height: 100vh;
  background: #f8fafc;
}

/* ===== 加载状态 ===== */
.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* ===== 头部区域 ===== */
.header {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 60rpx 32rpx 120rpx;
  position: relative;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ffffff;
  margin-bottom: 32rpx;
}

.item-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-bottom: 24rpx;
}

.item-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  display: block;
}

.item-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* ===== 内容区域 ===== */
.content {
  margin-top: -60rpx;
  padding: 0 32rpx 160rpx;
}

/* ===== 信息卡片 ===== */
.info-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #94a3b8;
  margin-bottom: 24rpx;
  display: block;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* ===== 信息项 ===== */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-label {
  font-size: 30rpx;
  color: #64748b;
  font-weight: 500;
}

.info-value {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 600;
}

.info-value.highlight {
  color: #6366f1;
}

.info-value.warning {
  color: #f59e0b;
}

.info-value.danger {
  color: #ef4444;
}

/* ===== 时间线 ===== */
.timeline {
  padding-left: 40rpx;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 2rpx;
  background: #e2e8f0;
}

.timeline-item {
  position: relative;
  padding-bottom: 32rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -36rpx;
  top: 8rpx;
  width: 20rpx;
  height: 20rpx;
  background: #6366f1;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.3);
}

.timeline-content {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
  display: block;
}

.timeline-time {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ===== 底部按钮 ===== */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx 48rpx;
  background: linear-gradient(to top, #ffffff 0%, rgba(255, 255, 255, 0.9) 100%);
  display: flex;
  gap: 20rpx;
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-btn::after {
  border: none;
}

.btn-edit {
  background: #f1f5f9;
  color: #64748b;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(99, 102, 241, 0.3);
}

/* ===== 删除确认弹窗 ===== */
.delete-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(15, 23, 42, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  backdrop-filter: blur(4rpx);
}

.delete-modal-card {
  width: 85%;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  animation: fadeIn 0.2s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.delete-icon {
  width: 120rpx;
  height: 120rpx;
  background: #fef2f2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin: 0 auto 32rpx;
}

.delete-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  margin-bottom: 16rpx;
  display: block;
}

.delete-desc {
  font-size: 28rpx;
  color: #64748b;
  text-align: center;
  margin-bottom: 40rpx;
  display: block;
}

.delete-modal-btns {
  display: flex;
  gap: 20rpx;
}

.delete-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn::after {
  border: none;
}

.delete-btn.cancel {
  background: #f1f5f9;
  color: #64748b;
}

.delete-btn.confirm {
  background: #ef4444;
  color: #ffffff;
}
