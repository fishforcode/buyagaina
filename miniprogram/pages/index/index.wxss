/* pages/index/index.wxss - 莫兰迪色系清新风格 */

/* ===== 基础布局 ===== */
.container {
  min-height: 100vh;
  background: #F5F5F3;
  padding: 0;
}

/* ===== 导航栏 ===== */
.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 62, 0.04);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F5F3;
}

.nav-icon {
  font-size: 36rpx;
  color: #2C3E3E;
  font-weight: 300;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #2C3E3E;
}

.nav-placeholder {
  width: 64rpx;
}

/* ===== 页面头部 ===== */
.header {
  padding: 48rpx 32rpx 32rpx;
  background: #FFFFFF;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
  margin-bottom: 24rpx;
}

.welcome {
  display: block;
  font-size: 44rpx;
  font-weight: 300;
  color: #2C3E3E;
  margin-bottom: 8rpx;
  letter-spacing: 0.02em;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #5A6C6C;
  font-weight: 300;
  letter-spacing: 0.01em;
}

/* ===== 快捷功能栏 ===== */
.quick-actions {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.action-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
  transition: all 0.2s ease;
  border-left: 4rpx solid transparent;
}

.action-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 62, 0.04);
}

.action-item.active {
  border-left-color: #8BA888;
  background: rgba(139, 168, 136, 0.05);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(124, 154, 146, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.action-item.active .action-icon {
  background: rgba(139, 168, 136, 0.15);
}

.action-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 30rpx;
  font-weight: 400;
  color: #2C3E3E;
  line-height: 1.4;
}

.action-status {
  font-size: 24rpx;
  color: #5A6C6C;
  margin-top: 4rpx;
  font-weight: 300;
}

.action-item.active .action-status {
  color: #8BA888;
}

.action-arrow {
  font-size: 32rpx;
  color: #B8C4BB;
  font-weight: 300;
}

/* ===== 空间列表 ===== */
.location-section {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #2C3E3E;
}

.section-count {
  font-size: 24rpx;
  color: #5A6C6C;
  font-weight: 300;
}

.location-list {
  padding: 0;
}

.location-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
  transition: all 0.2s ease;
  border-left: 4rpx solid transparent;
}

.location-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 62, 0.04);
}

.location-item.shared-item {
  border-left-color: #E8B4B8;
  background: rgba(232, 180, 184, 0.02);
}

.location-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(124, 154, 146, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.location-info-wrap {
  flex: 1;
}

.location-name {
  font-size: 30rpx;
  font-weight: 400;
  color: #2C3E3E;
  margin-bottom: 6rpx;
  display: block;
}

.location-info {
  font-size: 24rpx;
  color: #5A6C6C;
  font-weight: 300;
}

.location-arrow {
  font-size: 32rpx;
  color: #B8C4BB;
}

/* ===== 添加按钮 ===== */
.add-button {
  padding: 0 32rpx;
  margin-top: 32rpx;
  text-align: center;
}

.add-button button {
  width: 100%;
  height: 96rpx;
  background: #FFFFFF;
  color: #7C9A92;
  font-size: 28rpx;
  font-weight: 400;
  border-radius: 24rpx;
  border: 2rpx dashed #B8C4BB;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.04);
}

.add-button button::after {
  border: none;
}

.add-button button:active {
  background: rgba(124, 154, 146, 0.05);
  border-color: #7C9A92;
}

/* ===== 加载状态 ===== */
.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #B8C4BB;
  border-top-color: #7C9A92;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading text {
  font-size: 26rpx;
  color: #5A6C6C;
  font-weight: 300;
}

/* ===== 新用户引导页 ===== */
.welcome-page {
  padding: 80rpx 40rpx;
  text-align: center;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #F5F5F3;
}

.guide-card {
  background: transparent;
  padding: 0;
  box-shadow: none;
}

.guide-image {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 48rpx;
  background: rgba(124, 154, 146, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.15);
}

.guide-image::after {
  content: '🏠';
  font-size: 80rpx;
}

.guide-title {
  font-size: 40rpx;
  font-weight: 300;
  color: #2C3E3E;
  margin-bottom: 16rpx;
  display: block;
  letter-spacing: 0.02em;
}

.guide-desc {
  font-size: 26rpx;
  color: #5A6C6C;
  line-height: 1.6;
  margin-bottom: 48rpx;
  display: block;
  padding: 0 20rpx;
  font-weight: 300;
}

.guide-button {
  width: 80%;
  height: 96rpx;
  background: #7C9A92;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 400;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
}

.guide-button::after {
  border: none;
}

/* ===== 订阅消息授权弹窗 ===== */
.subscribe-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(44, 62, 62, 0.4);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  backdrop-filter: blur(8rpx);
}

.subscribe-card {
  width: 85%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(44, 62, 62, 0.12);
  animation: modalFadeIn 0.3s ease-out;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.subscribe-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(212, 165, 116, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin: 0 auto 32rpx;
}

.subscribe-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #2C3E3E;
  text-align: center;
  margin-bottom: 16rpx;
}

.subscribe-desc {
  font-size: 26rpx;
  color: #5A6C6C;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 32rpx;
  font-weight: 300;
}

.subscribe-tips {
  background: rgba(124, 154, 146, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.subscribe-tips text {
  display: block;
  font-size: 26rpx;
  color: #2C3E3E;
  line-height: 1.8;
  padding-left: 32rpx;
  position: relative;
  font-weight: 300;
}

.subscribe-tips text::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 16rpx;
  height: 16rpx;
  background: #7C9A92;
  border-radius: 50%;
}

.subscribe-button {
  width: 100%;
  height: 88rpx;
  background: #7C9A92;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 400;
  border-radius: 44rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
}

.subscribe-button::after {
  border: none;
}

.subscribe-skip {
  text-align: center;
  font-size: 24rpx;
  color: #5A6C6C;
  padding: 16rpx;
  font-weight: 300;
}

/* ===== 临期提醒检查按钮 ===== */
.check-expiry-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.check-expiry-btn {
  width: 100%;
  height: 96rpx;
  background: #7C9A92;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 400;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  padding: 0 20rpx;
}

.check-expiry-btn::after {
  border: none;
}

.check-expiry-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(124, 154, 146, 0.15);
}