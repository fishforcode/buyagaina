/* pages/index/index.wxss - 清新简约风 */

/* ===== 基础布局 ===== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #f8fafc 30%, #f8fafc 100%);
  padding: 0 32rpx 40rpx;
}

/* ===== 头部区域 ===== */
.header {
  padding: 60rpx 0 40rpx;
}

.welcome {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
  letter-spacing: -0.02em;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  font-weight: 400;
}

/* ===== 快捷功能栏 ===== */
.quick-actions {
  margin-bottom: 32rpx;
}

.action-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(99, 102, 241, 0.08);
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.action-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(99, 102, 241, 0.05);
}

.action-item.active {
  border-color: #6366f1;
  background: linear-gradient(135deg, #eef2ff 0%, #ffffff 100%);
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.3);
}

.action-item.active .action-icon {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.3);
}

.action-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.4;
}

.action-status {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
  font-weight: 500;
}

.action-item.active .action-status {
  color: #10b981;
}

.action-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  font-weight: 300;
}

/* ===== 空间列表 ===== */
.location-section {
  margin-top: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.section-count {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 500;
}

.location-list {
  background: transparent;
  padding: 0;
  box-shadow: none;
}

.location-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
  border-left: 6rpx solid #6366f1;
}

.location-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
}

.location-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.location-info-wrap {
  flex: 1;
}

.location-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
  display: block;
}

.location-info {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 500;
}

.location-arrow {
  font-size: 32rpx;
  color: #cbd5e1;
}

/* ===== 添加按钮 ===== */
.add-button {
  margin-top: 40rpx;
  text-align: center;
}

.add-button button {
  width: 100%;
  height: 96rpx;
  background: #ffffff;
  color: #6366f1;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: 2rpx dashed #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.add-button button::after {
  border: none;
}

.add-button button:active {
  background: #f8fafc;
  border-color: #6366f1;
}

/* ===== 加载状态 ===== */
.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* ===== 新用户引导页 ===== */
.welcome-page {
  padding: 80rpx 40rpx;
  text-align: center;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.guide-card {
  background: transparent;
  padding: 0;
  box-shadow: none;
}

.guide-image {
  width: 280rpx;
  height: 280rpx;
  margin: 0 auto 60rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a855f7 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(99, 102, 241, 0.3);
}

.guide-image::after {
  content: '🏠';
  font-size: 120rpx;
}

.guide-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 20rpx;
  display: block;
}

.guide-desc {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.6;
  margin-bottom: 60rpx;
  display: block;
  padding: 0 20rpx;
}

.guide-button {
  width: 80%;
  height: 96rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(99, 102, 241, 0.3);
}

.guide-button::after {
  border: none;
}

/* ===== 订阅消息授权弹窗 ===== */
.subscribe-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(15, 23, 42, 0.6);
  display: flex;
  justify-content: center;
  align-items: flex-end;
  z-index: 9999;
  backdrop-filter: blur(4rpx);
}

.subscribe-card {
  width: 100%;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 48rpx 40rpx 60rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.subscribe-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin: 0 auto 32rpx;
}

.subscribe-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  margin-bottom: 16rpx;
}

.subscribe-desc {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 40rpx;
}

.subscribe-tips {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.subscribe-tips text {
  display: block;
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
  padding-left: 40rpx;
  position: relative;
}

.subscribe-tips text::before {
  content: '';
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 24rpx;
  height: 24rpx;
  background: #6366f1;
  border-radius: 50%;
}

.subscribe-button {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(99, 102, 241, 0.3);
}

.subscribe-button::after {
  border: none;
}

.subscribe-skip {
  text-align: center;
  font-size: 28rpx;
  color: #94a3b8;
  padding: 20rpx;
  font-weight: 500;
}

/* ===== 临期提醒检查按钮 ===== */
.check-expiry-section {
  margin-top: 60rpx;
  padding: 0 8rpx;
}

.check-expiry-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-expiry-btn::after {
  border: none;
}

.check-expiry-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.25);
}

/* ===== 列表标题 ===== */
.list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
}
