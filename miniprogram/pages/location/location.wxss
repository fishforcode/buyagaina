/* pages/location/location.wxss - 莫兰迪色系清新风格 */

.container {
  min-height: 100vh;
  background: #F5F5F3;
}

/* ===== 加载状态 ===== */
.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #B8C4BB;
  border-top-color: #7C9A92;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading text {
  font-size: 26rpx;
  color: #5A6C6C;
  font-weight: 300;
}

/* ===== 头部区域 ===== */
.header {
  background: #FFFFFF;
  padding: 48rpx 32rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
  margin-bottom: 24rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 300;
  color: #2C3E3E;
  flex: 1;
  letter-spacing: 0.02em;
}

.header-actions {
  display: flex;
  gap: 12rpx;
}

.header-btn {
  height: 56rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  border-radius: 28rpx;
  background: rgba(124, 154, 146, 0.1);
  color: #7C9A92;
  border: 1rpx solid rgba(124, 154, 146, 0.2);
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-btn::after {
  border: none;
}

.subtitle {
  font-size: 26rpx;
  color: #5A6C6C;
  font-weight: 300;
  letter-spacing: 0.01em;
}

/* ===== 主体内容区 ===== */
.main {
  padding: 0 32rpx 180rpx;
}

/* ===== 统计卡片 ===== */
.stats-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 300;
  color: #7C9A92;
  display: block;
  margin-bottom: 6rpx;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #5A6C6C;
  font-weight: 300;
}

/* ===== 物品列表 ===== */
.section-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #2C3E3E;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 62, 0.06);
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
  border-left: 4rpx solid transparent;
}

.item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 62, 0.04);
}

.item-info {
  flex: 1;
  margin-right: 20rpx;
}

.item-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 400;
  color: #2C3E3E;
  flex: 1;
}

.item-quantity {
  font-size: 24rpx;
  color: #7C9A92;
  font-weight: 400;
  background: rgba(124, 154, 146, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.item-footer {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-expiry {
  font-size: 24rpx;
  color: #5A6C6C;
  font-weight: 300;
}

.item-expiry.expired {
  color: #C4786A;
}

.item-expiry.expiring {
  color: #D4A574;
}

.item-time {
  font-size: 22rpx;
  color: #B8C4BB;
  font-weight: 300;
}

/* ===== 操作按钮组 ===== */
.item-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.btn-action {
  height: 52rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  border-radius: 26rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 80rpx;
}

.btn-action::after {
  border: none;
}

.btn-edit {
  background: rgba(124, 154, 146, 0.1);
  color: #7C9A92;
}

.btn-consume {
  background: rgba(139, 168, 136, 0.1);
  color: #8BA888;
}

.btn-delete {
  background: rgba(196, 120, 106, 0.1);
  color: #C4786A;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(124, 154, 146, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 300;
  color: #2C3E3E;
  margin-bottom: 8rpx;
  display: block;
}

.empty-desc {
  font-size: 24rpx;
  color: #5A6C6C;
  display: block;
  font-weight: 300;
}

/* ===== 底部按钮 ===== */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx 48rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 12rpx rgba(44, 62, 62, 0.06);
}

.add-button {
  width: 100%;
  height: 96rpx;
  background: #7C9A92;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 400;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
}

.add-button::after {
  border: none;
}

.add-button:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(124, 154, 146, 0.15);
}

/* ===== 弹窗样式 ===== */
.consume-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(44, 62, 62, 0.4);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  backdrop-filter: blur(8rpx);
}

.consume-modal-card {
  width: 85%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(44, 62, 62, 0.12);
  animation: modalFadeIn 0.3s ease-out;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.consume-modal-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #2C3E3E;
  text-align: center;
  margin-bottom: 24rpx;
}

.consume-modal-qty {
  font-size: 26rpx;
  color: #5A6C6C;
  text-align: center;
  margin-bottom: 24rpx;
  font-weight: 300;
}

.consume-modal-label {
  font-size: 24rpx;
  color: #5A6C6C;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 300;
}

.consume-quick-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.consume-quick-btn {
  flex: 1;
  height: 72rpx;
  background: rgba(124, 154, 146, 0.1);
  color: #7C9A92;
  font-size: 26rpx;
  font-weight: 400;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.consume-quick-btn::after {
  border: none;
}

.consume-quick-btn:active {
  background: rgba(124, 154, 146, 0.15);
}

.consume-input {
  height: 88rpx;
  background: #F5F5F3;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2C3E3E;
  text-align: center;
  margin-bottom: 32rpx;
  border: 2rpx solid #B8C4BB;
}

.consume-modal-btns {
  display: flex;
  gap: 16rpx;
}

.consume-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
}

.consume-btn::after {
  border: none;
}

.consume-btn.cancel {
  background: #F5F5F3;
  color: #5A6C6C;
}

.consume-btn.confirm {
  background: #7C9A92;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(124, 154, 146, 0.2);
}

/* 重命名弹窗 */
.rename-modal .consume-input {
  text-align: left;
}