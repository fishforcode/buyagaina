/* pages/location/location.wxss - 清新简约风 */

.container {
  min-height: 100vh;
  background: #f8fafc;
}

/* ===== 加载状态 ===== */
.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* ===== 头部区域 ===== */
.header {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 60rpx 32rpx 48rpx;
  position: relative;
  border-radius: 0 0 32rpx 32rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  flex: 1;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.header-btn {
  height: 56rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-btn::after {
  border: none;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

/* ===== 主体内容区 ===== */
.main {
  padding: 48rpx 32rpx 160rpx;
}

/* ===== 统计卡片 ===== */
.stats-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  margin-top: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #6366f1;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

/* ===== 物品列表 ===== */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}

.item:active {
  transform: scale(0.98);
}

.item-info {
  flex: 1;
  margin-right: 20rpx;
}

.item-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
}

.item-quantity {
  font-size: 28rpx;
  color: #6366f1;
  font-weight: 600;
  background: #eef2ff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.item-footer {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-expiry {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.item-expiry.expired {
  color: #ef4444;
}

.item-expiry.expiring {
  color: #f59e0b;
}

.item-time {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ===== 操作按钮组 ===== */
.item-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.btn-action {
  height: 56rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border-radius: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 88rpx;
}

.btn-action::after {
  border: none;
}

.btn-edit {
  background: #f1f5f9;
  color: #64748b;
}

.btn-consume {
  background: #eef2ff;
  color: #6366f1;
}

.btn-delete {
  background: #fef2f2;
  color: #ef4444;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
  text-align: center;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
  display: block;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
  display: block;
}

/* ===== 底部按钮 ===== */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx 48rpx;
  background: linear-gradient(to top, #ffffff 0%, rgba(255, 255, 255, 0.9) 100%);
}

.add-button {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(99, 102, 241, 0.3);
}

.add-button::after {
  border: none;
}

.add-button:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(99, 102, 241, 0.2);
}

/* ===== 弹窗样式 ===== */
.consume-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(15, 23, 42, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  backdrop-filter: blur(4rpx);
}

.consume-modal-card {
  width: 85%;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  animation: fadeIn 0.2s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.consume-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  margin-bottom: 32rpx;
}

.consume-modal-qty {
  font-size: 28rpx;
  color: #64748b;
  text-align: center;
  margin-bottom: 32rpx;
  font-weight: 500;
}

.consume-modal-label {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 20rpx;
  display: block;
  font-weight: 500;
}

.consume-quick-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.consume-quick-btn {
  flex: 1;
  height: 72rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.consume-quick-btn::after {
  border: none;
}

.consume-quick-btn:active {
  background: #e2e8f0;
}

.consume-input {
  height: 88rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1e293b;
  text-align: center;
  margin-bottom: 40rpx;
  border: 2rpx solid #e2e8f0;
}

.consume-modal-btns {
  display: flex;
  gap: 20rpx;
}

.consume-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.consume-btn::after {
  border: none;
}

.consume-btn.cancel {
  background: #f1f5f9;
  color: #64748b;
}

.consume-btn.confirm {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
}

/* 重命名弹窗 */
.rename-modal .consume-input {
  text-align: left;
}
